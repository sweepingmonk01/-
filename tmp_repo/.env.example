# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional: Mobius backend local server port.
MOBIUS_SERVER_PORT="8787"
MOBIUS_DATA_DIR="server/data"
MOBIUS_STORAGE_PROVIDER="sqlite"
MOBIUS_SQLITE_DB_FILE="server/data/mobius.sqlite"
MOBIUS_VIDEO_PROVIDER="stub"

# Optional: future Seedance provider credentials for the Mobius backend.
SEEDANCE_API_KEY="MY_SEEDANCE_API_KEY"
SEEDANCE_BASE_URL="https://api.seedance.example.com"
SEEDANCE_CREATE_PATH="/v1/videos/generations"
SEEDANCE_STATUS_PATH_TEMPLATE="/v1/videos/generations/:jobId"
SEEDANCE_MODEL="seedance-1-0-lite"

# Optional: frontend override for calling Mobius without relying on Vite proxy.
MOBIUS_API_BASE_URL=""

# Optional: Vite dev proxy target for /api requests.
MOBIUS_API_PROXY_TARGET="http://localhost:8787"
