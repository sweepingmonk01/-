# DEEPSEEK_API_KEY: Required for DeepSeek AI API calls.
# DeepSeek uses an OpenAI-compatible API format.
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_FLASH_MODEL="deepseek-v4-flash"
DEEPSEEK_PRO_MODEL="deepseek-v4-pro"
DEEPSEEK_REASONING_EFFORT="high"
DEEPSEEK_THINKING_ENABLED="true"
DEEPSEEK_TIMEOUT_MS="30000"
DEEPSEEK_MAX_RETRIES="1"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Mobius Video Orchestration
# If using the 'seedance-http' engine, configure secrets below:
MOBIUS_VIDEO_PROVIDER=seedance-http
SEEDANCE_API_KEY="YOUR_SEEDANCE_API_KEY"
SEEDANCE_BASE_URL="YOUR_SEEDANCE_BASE_URL"
SEEDANCE_MODEL="seedance-1-0-lite"

# GPT-image-2 Knowledge Map Assets
# Without OPENAI_API_KEY the backend uses a deterministic stub asset so UI flows still work.
OPENAI_API_KEY=""
OPENAI_IMAGE_BASE_URL="https://api.openai.com"
OPENAI_IMAGE_MODEL="gpt-image-2"

# Mobius Environment Override
MOBIUS_SERVER_PORT="3000"
MOBIUS_DATA_DIR="server/data"
MOBIUS_STORAGE_PROVIDER="sqlite"
MOBIUS_SQLITE_DB_FILE="server/data/mobius.sqlite"

# Auth
# In production, demo mode defaults to disabled. Set true only for controlled demos.
MOBIUS_FIREBASE_PROJECT_ID=""
MOBIUS_DEMO_STUDENT_ID="demo-student"
MOBIUS_DEMO_MODE_ENABLED="true"
MOBIUS_AUTH_TEST_SECRET=""
MOBIUS_AGENT_JOB_POLL_MS="1500"

# Explore Sync HTTP Client
# Default frontend sync client remains mock unless VITE_EXPLORE_SYNC_CLIENT is set to http.
VITE_EXPLORE_SYNC_CLIENT="mock"
VITE_EXPLORE_SYNC_ENDPOINT="/api/explore/sync"
VITE_EXPLORE_API_BASE="/api/explore"
