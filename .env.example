# DEEPSEEK_API_KEY: Required for DeepSeek AI API calls.
# DeepSeek uses an OpenAI-compatible API format.
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_FLASH_MODEL="deepseek-v4-flash"
DEEPSEEK_PRO_MODEL="deepseek-v4-pro"
DEEPSEEK_REASONING_EFFORT="high"
DEEPSEEK_THINKING_ENABLED="true"
DEEPSEEK_TIMEOUT_MS="30000"
DEEPSEEK_MAX_RETRIES="1"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Mobius Video Orchestration
# If using the 'seedance-http' engine, configure secrets below:
MOBIUS_VIDEO_PROVIDER=seedance-http
SEEDANCE_API_KEY="YOUR_SEEDANCE_API_KEY"
SEEDANCE_BASE_URL="YOUR_SEEDANCE_BASE_URL"
SEEDANCE_MODEL="seedance-1-0-lite"

# GPT-image-2 Knowledge Map Assets
# Without OPENAI_API_KEY the backend uses a deterministic stub asset so UI flows still work.
OPENAI_API_KEY=""
OPENAI_IMAGE_BASE_URL="https://api.openai.com"
OPENAI_IMAGE_MODEL="gpt-image-2"

# Mobius Environment Override
MOBIUS_SERVER_PORT="3000"
MOBIUS_DATA_DIR="server/data"
MOBIUS_STORAGE_PROVIDER="sqlite"
MOBIUS_SQLITE_DB_FILE="server/data/mobius.sqlite"

# Auth
# In production, demo mode defaults to disabled. Set true only for controlled demos.
# MOBIUS_AUTH_PROVIDER selects the token verifier: "firebase" (default) or "supabase".
MOBIUS_AUTH_PROVIDER="firebase"
MOBIUS_FIREBASE_PROJECT_ID=""
# Supabase auth (only used when MOBIUS_AUTH_PROVIDER=supabase).
# MOBIUS_SUPABASE_URL: Project URL, e.g. https://<ref>.supabase.co
# MOBIUS_SUPABASE_JWT_SECRET: legacy HS256 JWT secret (Project Settings -> API -> JWT).
#   Leave empty to verify asymmetric tokens via the project's JWKS endpoint instead.
#   Never expose the service_role key here or in the frontend.
MOBIUS_SUPABASE_URL=""
MOBIUS_SUPABASE_JWT_SECRET=""

# Phone OTP login via Supabase "Send SMS" auth hook -> Tencent Cloud SMS.
# MOBIUS_SUPABASE_SMS_HOOK_SECRET: the hook secret Supabase generates (v1,whsec_...).
#   The /api/auth/hooks/send-sms endpoint verifies every hook call against it.
# MOBIUS_SMS_PROVIDER: "stub" (default, sends nothing) or "tencent".
# When "tencent", all TENCENT_SMS_* below are required; SignName/TemplateId must be
# pre-approved in 腾讯云短信控制台. Never expose these secrets in the frontend.
MOBIUS_SUPABASE_SMS_HOOK_SECRET=""
MOBIUS_SMS_PROVIDER="stub"
TENCENT_SMS_SECRET_ID=""
TENCENT_SMS_SECRET_KEY=""
TENCENT_SMS_SDK_APP_ID=""
TENCENT_SMS_SIGN_NAME=""
TENCENT_SMS_TEMPLATE_ID=""
TENCENT_SMS_REGION="ap-guangzhou"
MOBIUS_DEMO_STUDENT_ID="demo-student"
MOBIUS_DEMO_MODE_ENABLED="true"
MOBIUS_AUTH_TEST_SECRET=""
MOBIUS_AGENT_JOB_POLL_MS="1500"

# Explore Sync HTTP Client
# Default frontend sync client remains mock unless VITE_EXPLORE_SYNC_CLIENT is set to http.
VITE_EXPLORE_SYNC_CLIENT="mock"
VITE_EXPLORE_SYNC_ENDPOINT="/api/explore/sync"
VITE_EXPLORE_API_BASE="/api/explore"
